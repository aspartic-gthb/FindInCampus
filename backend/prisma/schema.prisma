// Lost and Found System - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  phone     String?
  itemsLost Item[]   @relation("LostItems")
  itemsFound Item[]  @relation("FoundItems")
  claims    Claim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id          String   @id @default(cuid())
  type        ItemType // 'LOST' or 'FOUND'
  status      ItemStatus @default(ACTIVE) // ACTIVE, CLAIMED, RESOLVED, EXPIRED
  title       String
  description String
  category    String   // electronics, clothing, documents, etc.
  location    String   // building/area name
  latitude    Float?
  longitude   Float?
  imageUrl    String?
  foundDate   DateTime? // For found items
  lostDate    DateTime? // For lost items
  reporterId  String
  reporter    User     @relation("LostItems", fields: [reporterId], references: [id])
  foundReporterId String?
  foundReporter   User? @relation("FoundItems", fields: [foundReporterId], references: [id])
  claims      Claim[]
  matches     Match[] @relation("LostItem")
  foundMatches Match[] @relation("FoundItem")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, status])
  @@index([category])
  @@index([location])
}

enum ItemType {
  LOST
  FOUND
}

enum ItemStatus {
  ACTIVE
  PENDING_CLAIM
  CLAIMED
  RESOLVED
  EXPIRED
}

model Claim {
  id          String   @id @default(cuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id])
  claimantId  String
  claimant    User     @relation(fields: [claimantId], references: [id])
  status      ClaimStatus @default(PENDING)
  description String
  proofImage  String?
  verificationNotes String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([itemId, status])
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model Match {
  id           String   @id @default(cuid())
  lostItemId   String
  foundItemId  String
  lostItem     Item     @relation("LostItem", fields: [lostItemId], references: [id])
  foundItem    Item     @relation("FoundItem", fields: [foundItemId], references: [id])
  similarityScore Float
  isProcessed  Boolean  @default(false)
  matchedAt    DateTime @default(now())

  @@unique([lostItemId, foundItemId])
  @@index([isProcessed])
}
